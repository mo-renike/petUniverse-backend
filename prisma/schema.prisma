// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PET_OWNER
  VET
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  INPROGRESS
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  username  String   @unique
  role      UserRole @default(PET_OWNER)

  VetProfile       VetProfile?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  maxDailyAppointments Int? @default(5)

  bookedAppointments Appointment[] @relation("UserAppointments")
  vetAppointments    Appointment[] @relation("VetAppointments")
  Post               Post[]
  Comment            Comment[]

  @@map("users")
}

model VetProfile {
  id              String  @id @default(uuid())
  specialization  String
  yearsExperience Int     @map("years_experience")
  location        String
  phoneNumber     String
  isAvailable     Boolean @default(true)
  bio             String? @db.Text

  userId    String   @unique
  user  User @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vet_profiles")
}

//posts Post[]

//comments Comment[]

//Post Schema

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String

  comments Comment[]
}

//Comment Schema 

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  post   Post @relation(fields: [postId], references: [id])
  postId Int
}

model Appointment {
  id      String            @id @default(uuid())
  vetId   String
  userId  String
  details String
  status  AppointmentStatus @default(PENDING)

  scheduledAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vet  User @relation("VetAppointments", fields: [vetId], references: [id])
  user User @relation("UserAppointments", fields: [userId], references: [id])

  @@index([vetId, createdAt], name: "vet_created_at_index")
  @@index([userId, vetId, status], name: "user_vet_status_index")
  @@map("appointments")
}
