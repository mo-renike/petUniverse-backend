// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PET_OWNER
  VET
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  INPROGRESS
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  username  String   @unique
  role      UserRole @default(PET_OWNER)
  resetToken String?
  resetTokenExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

    maxDailyAppointments Int? @default(5)
  

  bookedAppiontment Appointment[] @relation("UserAppointments")
  vetAppiontment Appointment[] @relation("VetAppointments")


  @@map("users")
} 

model Appointment {
    id        String             @id @default(uuid())
  vetId     String
  userId    String
  details   String
  status    AppointmentStatus @default(PENDING)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  
  @@index([vetId, createdAt], name: "vet_created_at_index")
  @@index([userId, vetId, status], name: "user_vet_status_index")

  vet        User               @relation("VetAppointments", fields: [vetId], references: [id])
  user       User               @relation("UserAppointments", fields: [userId], references: [id])


  @@map("appointments")
}

